{
  "expo": {
    "name": "Password Manager",
    "slug": "password-manager-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "password-manager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.luisrocha.passwordmanager",
      "adaptiveIcon": {
        "backgroundColor": "#101820"
      }
    },
    "plugins": [
      "expo-router",
      "react-native-quick-crypto",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "root": "app"
      },
      "eas": {
        "projectId": ""
      }
    },
    "ios": {
      "bundleIdentifier": "com.luisrocha.passwordmanager"
    }
  }
}
