# For a real phone in local development, use a URL reachable from the phone, for example:
# EXPO_PUBLIC_PASSWORD_MANAGER_API_BASE_URL=http://192.168.1.50:3000
# Do not use localhost or vault.localhost from the phone.
# HTTP is accepted only in development builds. Non-development builds require HTTPS.
EXPO_PUBLIC_PASSWORD_MANAGER_API_BASE_URL=https://vault.localhost
